# Orígenes permitidos por CORS además de localhost:5173.
# Acepta varios separados por coma, sin espacios entre URLs.
# Ejemplo: https://chrono-vision.web.app,https://chrono-vision.vercel.app
FRONTEND_ORIGIN=

# API Key de Groq para narración histórica con IA (LLaMA 3).
# Obtén la tuya gratis en: https://console.groq.com
GROQ_API_KEY=
